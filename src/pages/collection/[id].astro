---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import AudioPlayer from "../../components/AudioPlayer.astro";

export function getStaticPaths() {
	// Scan all audio files from public/sounds/
	const allAudioFiles = Object.entries(import.meta.glob("/public/sounds/**/*.{ogg,mp3,wav}", { eager: true }));

	// Build a map of collection ID -> audio files
	const collectionFiles: Record<string, { name: string; src: string }[]> = {};

	for (const [path] of allAudioFiles) {
		// Path format: /public/sounds/{collection-id}/{subfolder/}filename.ext
		// Handle both /public/sounds/folder/file.ogg and /public/sounds/folder/subfolder/file.ogg
		const parts = path.replace("/public/sounds/", "").split("/");
		const collectionId = parts[0];
		const filename = parts[parts.length - 1];

		// Skip files without a valid collection folder
		if (!collectionId || !filename.match(/\.(ogg|mp3|wav)$/i)) continue;

		// Build the full relative path (including subdirectories)
		// parts = [collectionId, subfolder1, subfolder2, ..., filename]
		const fullPath = parts.slice(1).join("/"); // Everything after collectionId
		const src = `/sounds/${collectionId}/${fullPath}`;

		if (!collectionFiles[collectionId]) {
			collectionFiles[collectionId] = [];
		}
		collectionFiles[collectionId].push({
			name: fullPath, // Show full path as name for clarity
			src,
		});
	}

	// Sort files by name
	for (const id of Object.keys(collectionFiles)) {
		collectionFiles[id].sort((a, b) => a.name.localeCompare(b.name));
	}

	// Generate paths for all collections that have audio files
	return Object.entries(collectionFiles).map(([id, files]) => ({
		params: { id },
		props: {
			collection: {
				id,
				name: id.replace(/-/g, " ").replace(/\b\w/g, (c) => c.toUpperCase()),
				description: `${files.length} sound files`,
			},
			audioFiles: files,
		},
	}));
}

const { collection, audioFiles } = Astro.props;

// For now, show a message that the page needs to be generated
---

<BaseLayout title={collection.name}>
	<Header />

	<main>
		<h1 class="page-title">{collection.name}</h1>

		<nav class="breadcrumb">
			<a href="/">Collections</a>
			<span class="separator">/</span>
			<span class="current">{collection.name}</span>
		</nav>

		<section class="collection-header">
			<div class="header-content">
				<p class="collection-description">{collection.description}</p>
			</div>

			<div class="header-actions">
				<a href={`/download/${collection.id}`} class="btn btn-primary">
					<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
						<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
						<polyline points="7,10 12,15 17,10"></polyline>
						<line x1="12" y1="15" x2="12" y2="3"></line>
					</svg>
					Download All
				</a>
			</div>
		</section>

		<section class="audio-list">
			<div class="list-header">
				<h2 class="list-title">Sound Files</h2>
				<span class="list-count">{audioFiles.length} files</span>
			</div>

			<div class="player-list">
				{audioFiles.map((file, index) => <AudioPlayer id={`audio-${index}`} name={file.name} src={file.src} />)}
			</div>

			<div class="empty-state">
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
					<path d="M9 18V5l12-2v13"></path>
					<circle cx="6" cy="18" r="3"></circle>
					<circle cx="18" cy="16" r="3"></circle>
				</svg>
				<p>Audio files are loaded dynamically based on folder contents.</p>
				<p class="hint">The site will scan your audio folders to generate this page.</p>
			</div>
		</section>
	</main>

	<Footer />
</BaseLayout>

<style>
	main {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 1.5rem 3rem;
	}

	.page-title {
		font-family: var(--font-display);
		font-size: 1.5rem;
		color: var(--color-accent);
		margin-bottom: 0.5rem;
		padding-top: 0.5rem;
		font-weight: 600;
	}

	.breadcrumb {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.5rem 0;
		font-family: var(--font-mono);
		font-size: 0.75rem;
	}

	.breadcrumb a {
		color: var(--color-text-muted);
		transition: color 0.2s;
	}

	.breadcrumb a:hover {
		color: var(--color-accent);
	}

	.separator {
		color: var(--color-text-muted);
	}

	.current {
		color: var(--color-text);
	}

	.collection-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: 1rem;
		margin-bottom: 1.5rem;
		padding-bottom: 1rem;
		border-bottom: 1px solid var(--color-border);
	}

	.collection-title {
		font-family: var(--font-display);
		font-size: 1.25rem;
		color: var(--color-text);
		margin-bottom: 0.25rem;
		font-weight: 500;
	}

	.collection-description {
		color: var(--color-text-muted);
		font-size: 0.9375rem;
	}

	.header-actions {
		display: flex;
		gap: 0.5rem;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		gap: 0.375rem;
		padding: 0.5rem 0.75rem;
		font-family: var(--font-display);
		font-size: 0.9375rem;
		border: 1px solid;
		transition: all 0.15s;
	}

	.btn svg {
		width: 14px;
		height: 14px;
	}

	.btn-primary {
		background: var(--color-accent);
		color: #ffffff;
		border-color: var(--color-accent-dim);
	}

	.btn-primary:hover {
		background: var(--color-accent-dim);
	}

	.list-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 1rem;
	}

	.list-title {
		font-family: var(--font-display);
		font-size: 1.125rem;
		color: var(--color-text);
		font-weight: 500;
	}

	.list-count {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		color: var(--color-text-muted);
	}

	.player-list {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 0.5rem;
		margin-bottom: 2rem;
	}

	@media (max-width: 768px) {
		.player-list {
			grid-template-columns: 1fr;
		}
	}

	.empty-state {
		text-align: center;
		padding: 2.5rem 1.5rem;
		background: var(--color-bg-secondary);
		border: 1px dashed var(--color-border);
	}

	.empty-state svg {
		width: 48px;
		height: 48px;
		color: var(--color-text-muted);
		margin-bottom: 0.75rem;
	}

	.empty-state p {
		color: var(--color-text-muted);
		margin-bottom: 0.25rem;
		font-size: 0.9375rem;
	}

	.empty-state .hint {
		font-size: 0.8125rem;
		color: var(--color-text-muted);
	}

	@media (max-width: 640px) {
		.collection-header {
			flex-direction: column;
		}

		.collection-title {
			font-size: 1.25rem;
		}

		.header-actions {
			width: 100%;
		}

		.btn {
			flex: 1;
			justify-content: center;
		}
	}
</style>
