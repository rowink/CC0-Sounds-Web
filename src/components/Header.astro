---

---

<header class="header">
	<div class="header-content">
		<a href="/" class="logo">
			<svg class="logo-icon" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
				<circle cx="16" cy="16" r="14" stroke="currentColor" stroke-width="2"></circle>
				<path d="M12 10v12M16 8v16M20 12v8" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
			</svg>
			<span class="logo-text">CC0<span class="logo-accent">Sounds</span></span>
		</a>

		<nav class="nav">
			<a href="/" class="nav-link">Home</a>
			<a href="https://github.com/rowink/CC0-Sounds-Web" class="nav-link" target="_blank" rel="noopener">GitHub</a>
		</nav>
	</div>
</header>

<style>
	.header {
		background: var(--color-bg-secondary);
	}

	.header-content {
		max-width: 1400px;
		margin: 0 auto;
		padding: 0.75rem 1.5rem;
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	.logo {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-family: var(--font-display);
		font-size: 1.25rem;
		transition: opacity 0.2s;
	}

	.logo:hover {
		opacity: 0.7;
	}

	.logo-icon {
		width: 20px;
		height: 20px;
		color: var(--color-accent);
	}

	.logo-text {
		color: var(--color-text);
	}

	.logo-accent {
		color: var(--color-accent);
	}

	.nav {
		display: flex;
		gap: 1.5rem;
	}

	.nav-link {
		font-family: var(--font-display);
		font-size: 1rem;
		color: var(--color-text-secondary);
		transition: color 0.2s;
		position: relative;
	}

	.nav-link:hover {
		color: var(--color-accent);
	}

	.nav-link.active {
		color: var(--color-accent);
	}

	.nav-link.active::after {
		content: "";
		position: absolute;
		bottom: -2px;
		left: 0;
		right: 0;
		height: 2px;
		background: var(--color-accent);
	}

	@media (max-width: 640px) {
		.header-content {
			padding: 0.625rem 1rem;
		}

		.logo-text {
			display: none;
		}

		.nav {
			gap: 1rem;
		}
	}
</style>
