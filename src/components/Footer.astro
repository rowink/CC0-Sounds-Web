---
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-content">
    <div class="footer-brand">
      <span class="footer-logo">CC0 Sounds</span>
      <p class="footer-description">Free royalty-free sound effects for your projects.</p>
    </div>
    
    <div class="footer-links">
      <div class="footer-section">
        <h4 class="footer-heading">Resources</h4>
        <a href="/" class="footer-link">Browse Sounds</a>
        <a href="https://creativecommons.org/publicdomain/zero/1.0/" class="footer-link" target="_blank" rel="noopener">CC0 License</a>
      </div>
      
      <div class="footer-section">
        <h4 class="footer-heading">Project</h4>
        <a href="https://github.com" class="footer-link" target="_blank" rel="noopener">GitHub</a>
        <a href="#" class="footer-link">Contribute</a>
      </div>
    </div>
  </div>
  
  <div class="footer-bottom">
    <p>&copy; {currentYear} CC0 Sounds. All sounds are released under CC0 license.</p>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-bg-secondary);
    margin-top: 3rem;
  }

  .footer-content {
    max-width: 1400px;
    margin: 0 auto;
    padding: 2rem 1.5rem 1.5rem;
    display: flex;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .footer-brand {
    max-width: 280px;
  }

  .footer-logo {
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--color-accent);
    display: block;
    margin-bottom: 0.375rem;
    font-weight: 600;
  }

  .footer-description {
    color: var(--color-text-muted);
    font-size: 0.9375rem;
  }

  .footer-links {
    display: flex;
    gap: 3rem;
  }

  .footer-section {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-heading {
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--color-text);
    margin-bottom: 0.125rem;
    font-weight: 600;
  }

  .footer-link {
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--color-text-muted);
    transition: color 0.2s;
  }

  .footer-link:hover {
    color: var(--color-accent);
  }

  .footer-bottom {
    padding: 1rem;
    text-align: center;
  }

  .footer-bottom p {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }

  @media (max-width: 640px) {
    .footer-content {
      flex-direction: column;
      gap: 1.5rem;
    }

    .footer-links {
      gap: 1.5rem;
    }
  }
</style>
